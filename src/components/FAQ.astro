---
import { faqs } from '../data/site';

interface Props {
  tone?: 'light' | 'dark';
}

const { tone = 'light' } = Astro.props;

const wrap =
  tone === 'dark'
    ? 'divide-y divide-sky-blue/15 border-t border-b border-sky-blue/15'
    : 'divide-y divide-silver border-t border-b border-silver';
const question = tone === 'dark' ? 'text-white' : 'text-navy';
const answer = tone === 'dark' ? 'text-ice-gray/85' : 'text-ink/80';
const icon = tone === 'dark' ? 'text-sky-blue' : 'text-royal-blue';
const hover = tone === 'dark' ? 'hover:bg-sky-blue/5' : 'hover:bg-ice-gray';
---

<div class:list={[wrap]}>
  {
    faqs.map((item) => (
      <details class="group">
        <summary class:list={['cursor-pointer list-none flex items-start justify-between gap-6 py-6 px-2 transition-colors', hover]}>
          <h3 class:list={['font-heading font-semibold text-lg leading-snug', question]}>
            {item.question}
          </h3>
          <span
            class:list={['shrink-0 mt-1 w-7 h-7 rounded-full inline-flex items-center justify-center transition-transform group-open:rotate-45 ring-1 ring-current/20', icon]}
            aria-hidden="true"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 5v14M5 12h14" stroke-linecap="round" />
            </svg>
          </span>
        </summary>
        <div class:list={['px-2 pb-6 leading-relaxed', answer]}>{item.answer}</div>
      </details>
    ))
  }
</div>
