---
import { nav, site } from '../data/site';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/'
    ? path === '/'
    : path === href || path === `${href}/` || path.startsWith(`${href}/`);
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300 bg-transparent"
  data-state="top"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 h-20 md:h-24 flex items-center justify-between gap-6">
    <a href="/" class="flex items-center shrink-0" aria-label={site.name}>
      <img
        src="/logo-white-wide.png"
        alt={site.name}
        width="2648"
        height="709"
        class="hidden md:block h-9 lg:h-10 w-auto"
        loading="eager"
        decoding="sync"
      />
      <img
        src="/logo-white-scr.png"
        alt={site.name}
        width="1024"
        height="1024"
        class="md:hidden h-11 w-auto"
        loading="eager"
        decoding="sync"
      />
    </a>

    <nav class="hidden lg:flex items-center gap-9 ml-auto" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'relative text-[11px] uppercase tracking-[0.22em] font-semibold transition-colors py-2',
              "after:content-[''] after:absolute after:left-0 after:right-0 after:-bottom-0.5 after:h-px after:origin-center after:scale-x-0 after:bg-gradient-to-r after:from-royal-blue after:via-sky-blue after:to-silver after:transition-transform after:duration-300",
              isActive(item.href)
                ? 'text-sky-blue after:scale-x-100'
                : 'text-white/85 hover:text-white hover:after:scale-x-100',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3 lg:gap-4">
      <a
        href="/contact"
        class="hidden md:inline-flex items-center px-5 py-3 rounded-full bg-button-gradient text-white text-[11px] font-semibold uppercase tracking-[0.22em] border border-white/25 shadow-gloss-button hover:shadow-[0_18px_40px_rgba(20,92,255,0.42)] hover:-translate-y-0.5 transition-all duration-300"
      >
        Request a Quote
      </a>
      <button
        type="button"
        id="mobile-menu-toggle"
        class="lg:hidden inline-flex items-center justify-center w-10 h-10 text-white"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="square" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-navy border-t border-sky-blue/20"
  >
    <nav class="flex flex-col px-6 py-6 gap-1" aria-label="Mobile">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'py-3 text-base uppercase tracking-[0.22em] font-semibold border-b border-sky-blue/15',
              isActive(item.href) ? 'text-sky-blue' : 'text-white/90',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/contact"
        class="mt-4 inline-flex items-center justify-center px-5 py-3 rounded-full bg-button-gradient text-white text-xs font-semibold uppercase tracking-[0.22em] border border-white/25 shadow-gloss-button"
      >
        Request a Quote
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  const setSolid = () => {
    header?.classList.add('bg-navy/95', 'backdrop-blur-md', 'border-b', 'border-sky-blue/15', 'shadow-[0_10px_30px_rgba(11,31,58,0.35)]');
    header?.classList.remove('bg-transparent');
    if (header) header.dataset.state = 'scrolled';
  };
  const setTransparent = () => {
    header?.classList.remove('bg-navy/95', 'backdrop-blur-md', 'border-b', 'border-sky-blue/15', 'shadow-[0_10px_30px_rgba(11,31,58,0.35)]');
    header?.classList.add('bg-transparent');
    if (header) header.dataset.state = 'top';
  };

  // Pages other than home start solid (no hero overlap).
  const isHome = window.location.pathname === '/' || window.location.pathname === '';
  if (!isHome) setSolid();

  const onScroll = () => {
    if (window.scrollY > 8) setSolid();
    else if (isHome) setTransparent();
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  toggle?.addEventListener('click', () => {
    if (!menu) return;
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu.classList.toggle('hidden');
  });
</script>
