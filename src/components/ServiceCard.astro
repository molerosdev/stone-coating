---
interface Props {
  slug: string;
  title: string;
  short: string;
  image?: string;
  href?: string;
  tone?: 'light' | 'dark';
}

const { slug, title, short, image, href, tone = 'light' } = Astro.props;
const target = href ?? `/services#${slug}`;

const cardBase =
  tone === 'dark'
    ? 'bg-deep-blue/40 backdrop-blur-sm border border-sky-blue/25 shadow-gloss-card-dark hover:border-sky-blue/60'
    : 'bg-white border border-silver shadow-gloss-card hover:border-sky-blue/50';

const titleColor = tone === 'dark' ? 'text-white' : 'text-navy';
const bodyColor = tone === 'dark' ? 'text-ice-gray/85' : 'text-ink/75';
---

<article
  class:list={[
    'group relative overflow-hidden rounded-lg transition-all duration-500 flex flex-col h-full',
    'hover:-translate-y-1 hover:shadow-gloss-glow',
    cardBase,
  ]}
>
  <!-- Top blue accent line -->
  <span class="absolute top-0 left-0 right-0 h-[3px] bg-gloss-accent z-10" aria-hidden="true"></span>

  <div class="relative aspect-[4/3] overflow-hidden bg-deep-blue">
    {
      image ? (
        <img
          src={image}
          alt={title}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="absolute inset-0">
          <div class="absolute inset-0 bg-dark-card"></div>
          <div
            class="absolute inset-0 opacity-[0.06] mix-blend-screen"
            style="background-image: radial-gradient(circle at 1px 1px, #4DB8FF 1px, transparent 0); background-size: 18px 18px;"
            aria-hidden="true"
          ></div>
          <div class="absolute inset-0 flex items-end p-5">
            <span class="text-sky-blue/60 font-heading text-[10px] tracking-[0.28em] uppercase">
              Photo Coming Soon
            </span>
          </div>
        </div>
      )
    }
    <!-- Blue tint overlay on hover -->
    <div class="absolute inset-0 bg-gradient-to-t from-navy/85 via-navy/10 to-transparent group-hover:from-royal-blue/55 group-hover:via-royal-blue/10 transition-all duration-500"></div>
    <!-- Resin reflection sheen on hover -->
    <div class="absolute inset-0 bg-card-shine opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>
  </div>

  <div class="p-7 flex-1 flex flex-col relative">
    <h3 class:list={['font-heading font-semibold text-xl leading-snug', titleColor]}>{title}</h3>
    <p class:list={['mt-3 text-sm leading-relaxed flex-1', bodyColor]}>{short}</p>
    <a
      href={target}
      class="mt-6 inline-flex items-center text-royal-blue text-[11px] font-semibold uppercase tracking-[0.24em] hover:text-sky-blue transition-colors"
    >
      Request This Service
      <span class="ml-2 transition-transform group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
    </a>
  </div>
</article>
