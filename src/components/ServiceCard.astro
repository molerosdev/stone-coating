---
interface Props {
  slug: string;
  title: string;
  short: string;
  image?: string;
  href?: string;
}

const { slug, title, short, image, href } = Astro.props;
const target = href ?? `/services#${slug}`;
---

<article class="group relative bg-deep-gray border border-deep-gray hover:border-bronze/60 transition-colors duration-300 flex flex-col h-full">
  <div class="relative aspect-[4/3] overflow-hidden bg-charcoal">
    {
      image ? (
        <img
          src={image}
          alt={title}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="absolute inset-0">
          <div
            class="absolute inset-0 bg-gradient-to-br from-charcoal via-deep-gray to-charcoal"
          ></div>
          <div
            class="absolute inset-0 opacity-[0.04] mix-blend-screen"
            style="background-image: radial-gradient(circle at 1px 1px, #F5F3EF 1px, transparent 0); background-size: 18px 18px;"
            aria-hidden="true"
          ></div>
          <div class="absolute inset-0 flex items-end p-5">
            <span class="text-bronze/40 font-heading text-[10px] tracking-[0.28em] uppercase">
              Photo Coming Soon
            </span>
          </div>
        </div>
      )
    }
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal/90 via-charcoal/0 to-charcoal/0"></div>
  </div>
  <div class="p-7 flex-1 flex flex-col">
    <h3 class="font-heading font-semibold text-xl text-off-white leading-snug">{title}</h3>
    <p class="mt-3 text-concrete-gray text-sm leading-relaxed flex-1">{short}</p>
    <a
      href={target}
      class="mt-6 inline-flex items-center text-bronze text-[11px] font-semibold uppercase tracking-[0.24em] hover:text-stone-beige transition-colors"
    >
      Learn More
      <span class="ml-2 transition-transform group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
    </a>
  </div>
</article>
