---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import {
  contactMethodOptions,
  propertyTypeOptions,
  serviceWantedOptions,
  site,
} from '../data/site';

const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
const isConfigured = Boolean(accessKey);
---

<BaseLayout
  title="Request a Flooring Quote | Stone Coating & Resinous Oklahoma"
  description="Tell us about your flooring renovation project — epoxy, resinous, polished concrete, stone coating, sealing, garage floors, patios, driveways, or concrete repair. Serving residential, commercial, and industrial clients across Oklahoma."
>
  <PageHero
    eyebrow="Contact"
    title="Request a Flooring Renovation Quote"
    subtitle="Tell us about your project and our team will review your request."
  />

  <section class="py-20 md:py-28 bg-charcoal">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-12 gap-12">
      <!-- Form -->
      <div class="lg:col-span-7">
        {!isConfigured && (
          <div class="mb-8 border border-bronze/40 bg-bronze/10 p-5 text-sm text-stone-beige">
            <p class="font-heading uppercase tracking-[0.22em] text-xs text-bronze">Setup pending</p>
            <p class="mt-2 leading-relaxed">
              Form submissions are not yet wired to an inbox. The site owner needs to add a Web3Forms access key as the <code>PUBLIC_WEB3FORMS_KEY</code> environment variable in Cloudflare Pages.
            </p>
          </div>
        )}

        <form
          id="contact-form"
          action="https://api.web3forms.com/submit"
          method="POST"
          enctype="multipart/form-data"
          class="space-y-6"
          novalidate
        >
          <input type="hidden" name="access_key" value={accessKey} />
          <input type="hidden" name="subject" value="New flooring quote request" />
          <input type="hidden" name="from_name" value={site.name} />
          <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

          <div class="grid sm:grid-cols-2 gap-6">
            <label class="block">
              <span class="block text-off-white/80 text-xs uppercase tracking-[0.22em] font-semibold mb-2">
                Full Name *
              </span>
              <input
                type="text"
                name="name"
                required
                class="w-full bg-deep-gray border border-deep-gray focus:border-bronze focus:outline-none px-4 py-3 text-off-white placeholder-concrete-gray/60"
                placeholder="Your name"
              />
            </label>
            <label class="block">
              <span class="block text-off-white/80 text-xs uppercase tracking-[0.22em] font-semibold mb-2">
                Phone Number *
              </span>
              <input
                type="tel"
                name="phone"
                required
                class="w-full bg-deep-gray border border-deep-gray focus:border-bronze focus:outline-none px-4 py-3 text-off-white placeholder-concrete-gray/60"
                placeholder="(555) 555-5555"
              />
            </label>
          </div>

          <label class="block">
            <span class="block text-off-white/80 text-xs uppercase tracking-[0.22em] font-semibold mb-2">
              Email *
            </span>
            <input
              type="email"
              name="email"
              required
              class="w-full bg-deep-gray border border-deep-gray focus:border-bronze focus:outline-none px-4 py-3 text-off-white placeholder-concrete-gray/60"
              placeholder="you@example.com"
            />
          </label>

          <div class="grid sm:grid-cols-2 gap-6">
            <label class="block">
              <span class="block text-off-white/80 text-xs uppercase tracking-[0.22em] font-semibold mb-2">
                Service Wanted *
              </span>
              <select
                id="service-select"
                name="service"
                required
                class="w-full bg-deep-gray border border-deep-gray focus:border-bronze focus:outline-none px-4 py-3 text-off-white"
              >
                <option value="">Select a service</option>
                {serviceWantedOptions.map((opt) => <option value={opt}>{opt}</option>)}
              </select>
            </label>
            <label class="block">
              <span class="block text-off-white/80 text-xs uppercase tracking-[0.22em] font-semibold mb-2">
                Residential or Commercial *
              </span>
              <select
                name="property_type"
                required
                class="w-full bg-deep-gray border border-deep-gray focus:border-bronze focus:outline-none px-4 py-3 text-off-white"
              >
                <option value="">Select a property type</option>
                {propertyTypeOptions.map((opt) => <option value={opt}>{opt}</option>)}
              </select>
            </label>
          </div>

          <label class="block">
            <span class="block text-off-white/80 text-xs uppercase tracking-[0.22em] font-semibold mb-2">
              Preferred Contact Method *
            </span>
            <select
              name="contact_method"
              required
              class="w-full bg-deep-gray border border-deep-gray focus:border-bronze focus:outline-none px-4 py-3 text-off-white"
            >
              <option value="">Select a method</option>
              {contactMethodOptions.map((opt) => <option value={opt}>{opt}</option>)}
            </select>
          </label>

          <label class="block">
            <span class="block text-off-white/80 text-xs uppercase tracking-[0.22em] font-semibold mb-2">
              Project Photos (up to 3, optional)
            </span>
            <input
              id="photos-input"
              type="file"
              name="attachments"
              accept="image/jpeg,image/png,image/webp"
              multiple
              class="block w-full text-sm text-concrete-gray file:mr-4 file:py-3 file:px-5 file:border-0 file:bg-bronze file:text-charcoal file:font-semibold file:uppercase file:text-xs file:tracking-[0.18em] hover:file:bg-stone-beige cursor-pointer"
            />
            <span class="block mt-2 text-xs text-concrete-gray">JPG, PNG, or WEBP. Max 3 files, 5MB each.</span>
            <span id="photos-error" class="hidden mt-2 text-xs text-bronze"></span>
          </label>

          <label class="block">
            <span class="block text-off-white/80 text-xs uppercase tracking-[0.22em] font-semibold mb-2">
              Message *
            </span>
            <textarea
              name="message"
              required
              rows="5"
              class="w-full bg-deep-gray border border-deep-gray focus:border-bronze focus:outline-none px-4 py-3 text-off-white placeholder-concrete-gray/60 resize-y"
              placeholder="Tell us about your space, the surface condition, and what outcome you're looking for."
            ></textarea>
          </label>

          <div class="flex flex-col sm:flex-row sm:items-center gap-4 pt-2">
            <button
              type="submit"
              class="inline-flex items-center justify-center px-7 py-3 bg-bronze text-charcoal text-xs font-semibold uppercase tracking-[0.22em] hover:bg-stone-beige transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
            >
              <span class="submit-label">Send Request</span>
              <span class="submit-loading hidden">Sending...</span>
            </button>
            <p class="text-xs text-concrete-gray">By submitting, you agree to be contacted about your project request.</p>
          </div>

          <div
            id="form-success"
            class="hidden border border-bronze/40 bg-bronze/10 p-5 text-sm text-stone-beige"
            role="status"
          >
            <p class="font-heading uppercase tracking-[0.22em] text-xs text-bronze">Request received</p>
            <p class="mt-2 leading-relaxed">Thank you. We've received your project request and will follow up shortly using your preferred contact method.</p>
          </div>
          <div
            id="form-error"
            class="hidden border border-red-500/40 bg-red-500/10 p-5 text-sm text-red-200"
            role="alert"
          >
            <p class="font-heading uppercase tracking-[0.22em] text-xs text-red-300">Something went wrong</p>
            <p class="mt-2 leading-relaxed">We couldn't send your request. Please try again or reach us directly using the contact information on this page.</p>
          </div>
        </form>
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-5">
        <div class="bg-deep-gray border border-bronze/20 p-7 lg:p-9">
          <h2 class="font-heading font-semibold text-off-white text-xl">Contact Details</h2>
          <p class="mt-3 text-concrete-gray text-sm leading-relaxed">
            Final phone, email, and hours will be added once provided. In the meantime, please use the form to submit a project request.
          </p>

          <ul class="mt-7 space-y-5 text-sm">
            <li>
              <span class="block text-off-white/60 text-xs uppercase tracking-[0.22em] mb-1">Phone</span>
              <span class="text-off-white">{site.contact.phone}</span>
            </li>
            <li>
              <span class="block text-off-white/60 text-xs uppercase tracking-[0.22em] mb-1">Email</span>
              <span class="text-off-white">{site.contact.email}</span>
            </li>
            <li>
              <span class="block text-off-white/60 text-xs uppercase tracking-[0.22em] mb-1">Service Area</span>
              <span class="text-off-white">{site.serviceArea}</span>
            </li>
            <li>
              <span class="block text-off-white/60 text-xs uppercase tracking-[0.22em] mb-1">Business Hours</span>
              <span class="text-off-white">{site.contact.hours}</span>
            </li>
          </ul>
        </div>

        <div class="mt-6 bg-charcoal border border-deep-gray p-7">
          <h3 class="font-heading font-semibold text-off-white text-base">What to expect</h3>
          <ol class="mt-5 space-y-4 text-sm text-concrete-gray leading-relaxed">
            <li class="flex gap-4">
              <span class="text-bronze font-heading font-bold text-sm tracking-widest">01</span>
              <span>We review your request and any photos provided.</span>
            </li>
            <li class="flex gap-4">
              <span class="text-bronze font-heading font-bold text-sm tracking-widest">02</span>
              <span>We follow up using your preferred contact method to confirm details.</span>
            </li>
            <li class="flex gap-4">
              <span class="text-bronze font-heading font-bold text-sm tracking-widest">03</span>
              <span>We provide a recommendation, project scope, and quote.</span>
            </li>
          </ol>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');
  const error = document.getElementById('form-error');
  const photosInput = document.getElementById('photos-input') as HTMLInputElement | null;
  const photosError = document.getElementById('photos-error');
  const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  const submitLabel = submitButton?.querySelector('.submit-label');
  const submitLoading = submitButton?.querySelector('.submit-loading');

  const MAX_FILES = 3;
  const MAX_BYTES = 5 * 1024 * 1024;

  // Pre-fill service from query string (?service=Epoxy+Flooring)
  const params = new URLSearchParams(window.location.search);
  const requestedService = params.get('service');
  if (requestedService) {
    const select = document.getElementById('service-select') as HTMLSelectElement | null;
    if (select) {
      const match = Array.from(select.options).find((o) => o.value === requestedService);
      if (match) select.value = requestedService;
    }
  }

  photosInput?.addEventListener('change', () => {
    if (!photosInput.files || !photosError) return;
    const files = Array.from(photosInput.files);
    photosError.classList.add('hidden');
    photosError.textContent = '';
    if (files.length > MAX_FILES) {
      photosError.textContent = `Please attach a maximum of ${MAX_FILES} photos.`;
      photosError.classList.remove('hidden');
      photosInput.value = '';
      return;
    }
    const oversized = files.find((f) => f.size > MAX_BYTES);
    if (oversized) {
      photosError.textContent = `"${oversized.name}" exceeds the 5MB limit.`;
      photosError.classList.remove('hidden');
      photosInput.value = '';
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    success?.classList.add('hidden');
    error?.classList.add('hidden');

    if (submitButton) submitButton.disabled = true;
    submitLabel?.classList.add('hidden');
    submitLoading?.classList.remove('hidden');

    try {
      const formData = new FormData(form);
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData,
      });
      const json = await res.json();
      if (res.ok && json.success) {
        form.reset();
        success?.classList.remove('hidden');
        success?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        throw new Error(json.message ?? 'Submission failed');
      }
    } catch (err) {
      console.error(err);
      error?.classList.remove('hidden');
      error?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } finally {
      if (submitButton) submitButton.disabled = false;
      submitLabel?.classList.remove('hidden');
      submitLoading?.classList.add('hidden');
    }
  });
</script>
