---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FAQ from '../components/FAQ.astro';
import {
  contactMethodOptions,
  propertyTypeOptions,
  serviceWantedOptions,
  site,
} from '../data/site';

// FormSubmit handles delivery + file attachments for free.
// The bare-email endpoint can be swapped for a hashed alias from
// formsubmit.co later to keep the destination out of page source.
const formAction = `https://formsubmit.co/${site.contact.email}`;

const inputClass =
  'w-full bg-white border border-silver rounded-md focus:border-royal-blue focus:ring-2 focus:ring-royal-blue/20 focus:outline-none px-4 py-3 text-navy placeholder-ink/40 transition-all duration-200';
const labelClass =
  'block text-navy text-xs uppercase tracking-[0.22em] font-semibold mb-2';
---

<BaseLayout
  title="Request a Flooring Quote | Stone Coating & Resinous Oklahoma"
  description="Tell us about your flooring renovation project — epoxy, resinous, polished concrete, stone coating, sealing, garage floors, patios, driveways, or concrete repair. Serving residential, commercial, and industrial clients across Oklahoma."
>
  <PageHero
    eyebrow="Contact"
    title="Request a Flooring Renovation Quote"
    subtitle="Tell us about your project and our team will review your request."
  />

  <section class="py-20 md:py-28 bg-ice-gray">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-12 gap-12">
      <!-- Form -->
      <div class="lg:col-span-7">
        <div class="relative overflow-hidden rounded-lg border border-silver bg-white p-7 md:p-10 shadow-gloss-card">
          <span class="absolute top-0 left-0 right-0 h-[3px] bg-gloss-accent"></span>
          <form
            id="contact-form"
            action={formAction}
            method="POST"
            enctype="multipart/form-data"
            class="space-y-6"
            novalidate
          >
            <!-- FormSubmit controls -->
            <input type="hidden" name="_subject" value="New flooring quote request" />
            <input type="hidden" id="form-next" name="_next" value="/contact?sent=1" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_template" value="table" />
            <!-- Honeypot: must stay empty for the submission to be accepted -->
            <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" />

            <div class="grid sm:grid-cols-2 gap-6">
              <label class="block">
                <span class={labelClass}>Full Name *</span>
                <input type="text" name="name" required class={inputClass} placeholder="Your name" />
              </label>
              <label class="block">
                <span class={labelClass}>Phone Number *</span>
                <input type="tel" name="phone" required class={inputClass} placeholder="(555) 555-5555" />
              </label>
            </div>

            <label class="block">
              <span class={labelClass}>Email *</span>
              <input type="email" name="email" required class={inputClass} placeholder="you@example.com" />
            </label>

            <div class="grid sm:grid-cols-2 gap-6">
              <label class="block">
                <span class={labelClass}>Service Wanted *</span>
                <select id="service-select" name="service" required class={inputClass}>
                  <option value="">Select a service</option>
                  {serviceWantedOptions.map((opt) => <option value={opt}>{opt}</option>)}
                </select>
              </label>
              <label class="block">
                <span class={labelClass}>Residential or Commercial *</span>
                <select name="property_type" required class={inputClass}>
                  <option value="">Select a property type</option>
                  {propertyTypeOptions.map((opt) => <option value={opt}>{opt}</option>)}
                </select>
              </label>
            </div>

            <label class="block">
              <span class={labelClass}>Preferred Contact Method *</span>
              <select name="contact_method" required class={inputClass}>
                <option value="">Select a method</option>
                {contactMethodOptions.map((opt) => <option value={opt}>{opt}</option>)}
              </select>
            </label>

            <label class="block">
              <span class={labelClass}>Project Photos (up to 3, optional)</span>
              <input
                id="photos-input"
                type="file"
                name="attachments"
                accept="image/jpeg,image/png,image/webp"
                multiple
                class="block w-full text-sm text-ink/70 file:mr-4 file:py-3 file:px-5 file:border-0 file:rounded-full file:bg-button-gradient file:text-white file:font-semibold file:uppercase file:text-xs file:tracking-[0.18em] file:shadow-gloss-button hover:file:opacity-90 cursor-pointer"
              />
              <span class="block mt-2 text-xs text-ink/60">JPG, PNG, or WEBP. Max 3 files, 5MB each.</span>
              <span id="photos-error" class="hidden mt-2 text-xs text-red-600"></span>
            </label>

            <label class="block">
              <span class={labelClass}>Message *</span>
              <textarea
                name="message"
                required
                rows="5"
                class={`${inputClass} resize-y`}
                placeholder="Tell us about your space, the surface condition, and what outcome you're looking for."
              ></textarea>
            </label>

            <div class="flex flex-col sm:flex-row sm:items-center gap-4 pt-2">
              <button
                type="submit"
                class="group relative inline-flex items-center justify-center px-7 py-3 rounded-full text-white text-xs font-semibold uppercase tracking-[0.22em] bg-button-gradient border border-white/25 shadow-gloss-button hover:shadow-[0_18px_40px_rgba(20,92,255,0.42)] hover:-translate-y-0.5 transition-all duration-300 disabled:opacity-60 disabled:cursor-not-allowed disabled:hover:translate-y-0"
              >
                <span class="submit-label">Request My Quote</span>
                <span class="submit-loading hidden">Sending...</span>
              </button>
              <p class="text-xs text-ink/60">By submitting, you agree to be contacted about your project request.</p>
            </div>

            <div
              id="form-success"
              class="hidden rounded-md border border-royal-blue/40 bg-ice-gray p-5 text-sm text-navy"
              role="status"
            >
              <p class="font-heading uppercase tracking-[0.22em] text-xs text-royal-blue">Request received</p>
              <p class="mt-2 leading-relaxed">Thank you. We've received your project request and will follow up shortly using your preferred contact method.</p>
            </div>
          </form>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-5">
        <div class="relative overflow-hidden rounded-lg bg-dark-card border border-sky-blue/30 p-7 lg:p-9 shadow-gloss-card-dark">
          <span class="absolute top-0 left-0 right-0 h-[3px] bg-gloss-accent"></span>
          <h2 class="font-heading font-semibold text-white text-xl">Contact Details</h2>
          <p class="mt-3 text-ice-gray/80 text-sm leading-relaxed">
            Final phone, email, and hours will be added once provided. In the meantime, please use the form to submit a project request.
          </p>

          <ul class="mt-7 space-y-5 text-sm">
            <li>
              <span class="block text-sky-blue text-xs uppercase tracking-[0.22em] mb-1">Phone</span>
              <span class="text-white">{site.contact.phone}</span>
            </li>
            <li>
              <span class="block text-sky-blue text-xs uppercase tracking-[0.22em] mb-1">Email</span>
              <span class="text-white">{site.contact.email}</span>
            </li>
            <li>
              <span class="block text-sky-blue text-xs uppercase tracking-[0.22em] mb-1">Service Area</span>
              <span class="text-white">{site.serviceArea}</span>
            </li>
            <li>
              <span class="block text-sky-blue text-xs uppercase tracking-[0.22em] mb-1">Business Hours</span>
              <span class="text-white">{site.contact.hours}</span>
            </li>
          </ul>
        </div>

        <div class="mt-6 relative overflow-hidden rounded-lg bg-white border border-silver p-7 shadow-gloss-card">
          <span class="absolute top-0 left-0 right-0 h-[3px] bg-gloss-accent"></span>
          <h3 class="font-heading font-semibold text-navy text-base">What to expect</h3>
          <ol class="mt-5 space-y-4 text-sm text-ink/75 leading-relaxed">
            <li class="flex gap-4">
              <span class="font-heading font-bold text-sm tracking-widest bg-gradient-to-r from-royal-blue to-sky-blue bg-clip-text text-transparent">01</span>
              <span>We review your request and any photos provided.</span>
            </li>
            <li class="flex gap-4">
              <span class="font-heading font-bold text-sm tracking-widest bg-gradient-to-r from-royal-blue to-sky-blue bg-clip-text text-transparent">02</span>
              <span>We follow up using your preferred contact method to confirm details.</span>
            </li>
            <li class="flex gap-4">
              <span class="font-heading font-bold text-sm tracking-widest bg-gradient-to-r from-royal-blue to-sky-blue bg-clip-text text-transparent">03</span>
              <span>We provide a recommendation, project scope, and quote.</span>
            </li>
          </ol>
        </div>
      </aside>
    </div>
  </section>

  <!-- FAQ — White, sits at the bottom of the contact page -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-4xl mx-auto px-6 lg:px-10">
      <SectionHeading
        tone="light"
        eyebrow="FAQ"
        title="Frequently Asked Questions"
        description="Common questions about our flooring renovation services."
      />
      <div class="mt-12">
        <FAQ tone="light" />
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');
  const photosInput = document.getElementById('photos-input') as HTMLInputElement | null;
  const photosError = document.getElementById('photos-error');
  const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  const submitLabel = submitButton?.querySelector('.submit-label');
  const submitLoading = submitButton?.querySelector('.submit-loading');

  const MAX_FILES = 3;
  const MAX_BYTES = 5 * 1024 * 1024;

  const params = new URLSearchParams(window.location.search);

  // FormSubmit redirects to the URL in `_next` after processing. Set it to
  // the current origin so submissions on .pages.dev redirect back to
  // .pages.dev (instead of jumping to the production domain).
  const nextInput = document.getElementById('form-next') as HTMLInputElement | null;
  if (nextInput) {
    nextInput.value = `${window.location.origin}/contact?sent=1`;
  }

  // Show the success panel after FormSubmit redirects back with ?sent=1.
  if (params.get('sent') === '1' && success) {
    success.classList.remove('hidden');
    success.scrollIntoView({ behavior: 'smooth', block: 'center' });
    // Strip the flag from the URL so a refresh doesn't keep the panel up.
    const cleanUrl = window.location.pathname;
    history.replaceState(null, '', cleanUrl);
  }

  // Pre-fill service from query string (?service=Epoxy+Flooring)
  const requestedService = params.get('service');
  if (requestedService) {
    const select = document.getElementById('service-select') as HTMLSelectElement | null;
    if (select) {
      const match = Array.from(select.options).find((o) => o.value === requestedService);
      if (match) select.value = requestedService;
    }
  }

  // Client-side validation for the photo upload (count + size).
  photosInput?.addEventListener('change', () => {
    if (!photosInput.files || !photosError) return;
    const files = Array.from(photosInput.files);
    photosError.classList.add('hidden');
    photosError.textContent = '';
    if (files.length > MAX_FILES) {
      photosError.textContent = `Please attach a maximum of ${MAX_FILES} photos.`;
      photosError.classList.remove('hidden');
      photosInput.value = '';
      return;
    }
    const oversized = files.find((f) => f.size > MAX_BYTES);
    if (oversized) {
      photosError.textContent = `"${oversized.name}" exceeds the 5MB limit.`;
      photosError.classList.remove('hidden');
      photosInput.value = '';
    }
  });

  // Native submit (no preventDefault) so FormSubmit can accept multipart
  // file uploads and redirect on success. We only flip the button into a
  // loading state to prevent double-clicks while the browser navigates.
  form?.addEventListener('submit', () => {
    if (submitButton) submitButton.disabled = true;
    submitLabel?.classList.add('hidden');
    submitLoading?.classList.remove('hidden');
  });
</script>
