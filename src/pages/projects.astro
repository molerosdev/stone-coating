---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
import { projects } from '../data/site';
---

<BaseLayout
  title="Flooring Project Gallery | Stone Coating & Resinous Oklahoma"
  description="Selected flooring projects completed by Stone Coating & Resinous — polished concrete, epoxy flake, metallic epoxy, stone coating, terrazzo restoration, and more, across Oklahoma."
>
  <PageHero
    eyebrow="Project Gallery"
    title="A Portfolio of Recent Flooring Projects"
    subtitle="A selection of commercial and industrial flooring renovations across Oklahoma. Click any project for the full set of photos and the system applied."
  />

  <!-- Portfolio grid — 3 columns on desktop, 2 on tablet, 1 on mobile -->
  <section class="relative py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {
          projects.map((p) => (
            <a
              href={`/projects/${p.slug}/`}
              class="project-card group relative block overflow-hidden rounded-lg border border-silver bg-white shadow-gloss-card transition-all duration-300 hover:-translate-y-1 hover:shadow-gloss-glow hover:border-sky-blue/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-royal-blue"
              aria-label={`View project: ${p.title}`}
            >
              <span class="absolute top-0 left-0 right-0 h-[3px] bg-gloss-accent z-20" aria-hidden="true"></span>
              <div class="relative aspect-[4/5] overflow-hidden bg-deep-blue">
                <img
                  src={p.coverImage}
                  alt={p.title}
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]"
                />
                <!-- Bottom navy gradient so the title is always readable -->
                <div class="absolute inset-0 bg-gradient-to-t from-navy/90 via-navy/35 to-transparent transition-all duration-500 group-hover:from-royal-blue/80 group-hover:via-royal-blue/30"></div>
                <!-- Subtle gloss sheen on hover -->
                <div class="absolute inset-0 bg-card-shine opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>
                <!-- Title block -->
                <div class="absolute inset-x-0 bottom-0 p-6">
                  <p class="text-sky-blue text-[10px] font-semibold uppercase tracking-[0.28em]">{p.category}</p>
                  <h3 class="mt-2 font-heading font-semibold text-white text-lg md:text-xl leading-snug">
                    {p.title}
                  </h3>
                  <span class="mt-3 inline-flex items-center text-white/85 text-[11px] font-semibold uppercase tracking-[0.24em] transition-colors group-hover:text-white">
                    View Project
                    <span class="ml-2 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
