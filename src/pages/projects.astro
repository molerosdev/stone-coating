---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
import { projectCategories, projectPlaceholders } from '../data/site';
---

<BaseLayout
  title="Flooring Project Gallery | Stone Coating & Resinous Oklahoma"
  description="Explore residential, commercial, and industrial flooring renovation projects completed by Stone Coating & Resinous across Oklahoma."
>
  <PageHero
    eyebrow="Project Gallery"
    title="Flooring Projects Across Oklahoma"
    subtitle="Explore residential, commercial, and industrial flooring renovation projects completed by Stone Coating & Resinous."
  />

  <section class="py-16 md:py-24 bg-charcoal">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <!-- Filters -->
      <div class="border border-deep-gray bg-deep-gray/40 p-2">
        <ul id="project-filters" class="flex flex-wrap gap-1" role="tablist">
          {
            projectCategories.map((cat, idx) => (
              <li>
                <button
                  type="button"
                  class:list={[
                    'project-filter px-4 py-2 text-xs uppercase tracking-[0.18em] font-medium transition-colors',
                    idx === 0
                      ? 'bg-bronze text-charcoal'
                      : 'text-concrete-gray hover:text-off-white hover:bg-charcoal/60',
                  ]}
                  data-filter={cat}
                  aria-pressed={idx === 0 ? 'true' : 'false'}
                >
                  {cat}
                </button>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Grid -->
      <div id="project-grid" class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          projectPlaceholders.map((p) => (
            <article
              class="project-card group bg-deep-gray border border-deep-gray hover:border-bronze/60 transition-colors duration-300 flex flex-col cursor-pointer"
              data-category={p.category}
              data-type={p.type}
              data-title={p.title}
              data-service={p.service}
              data-location={p.location}
              data-image={p.image ?? ''}
            >
              <div class="relative aspect-[4/3] overflow-hidden bg-charcoal">
                {p.image ? (
                  <img
                    src={p.image}
                    alt={p.title}
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="absolute inset-0 bg-gradient-to-br from-charcoal via-deep-gray to-charcoal flex items-end p-5">
                    <span class="text-bronze/40 font-heading text-[10px] tracking-[0.28em] uppercase">Photo Coming Soon</span>
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-charcoal/85 via-charcoal/0 to-charcoal/0"></div>
              </div>
              <div class="p-6 flex-1 flex flex-col">
                <p class="text-bronze text-[10px] font-semibold uppercase tracking-[0.28em]">{p.type}</p>
                <h3 class="mt-3 font-heading font-semibold text-off-white text-lg leading-snug">{p.title}</h3>
                <p class="mt-2 text-concrete-gray text-sm flex-1">
                  {p.service} &middot; {p.location}
                </p>
                <span class="mt-4 inline-flex items-center text-bronze text-[11px] font-semibold uppercase tracking-[0.24em]">
                  View Details <span class="ml-2 transition-transform group-hover:translate-x-1" aria-hidden="true">&rarr;</span>
                </span>
              </div>
            </article>
          ))
        }
      </div>

      <p
        id="project-empty"
        class="hidden mt-12 text-center text-concrete-gray italic"
      >
        No projects in this category yet. Real project photos and videos will be added soon.
      </p>

      <p class="mt-16 text-concrete-gray text-sm italic text-center max-w-2xl mx-auto">
        Real project photos and videos coming soon. Below is a preview of the type of work we deliver.
      </p>
    </div>
  </section>

  <!-- Lightbox modal -->
  <div
    id="project-modal"
    class="fixed inset-0 z-[60] hidden items-center justify-center bg-charcoal/90 p-6"
    role="dialog"
    aria-modal="true"
    aria-labelledby="project-modal-title"
  >
    <button
      id="project-modal-close"
      type="button"
      class="absolute top-6 right-6 w-10 h-10 inline-flex items-center justify-center text-off-white hover:text-bronze"
      aria-label="Close"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M6 6l12 12M18 6l-12 12" stroke-linecap="square" />
      </svg>
    </button>
    <div class="bg-deep-gray border border-bronze/30 max-w-2xl w-full p-8 md:p-10">
      <p id="project-modal-eyebrow" class="text-bronze text-[11px] font-semibold uppercase tracking-[0.22em]"></p>
      <h2 id="project-modal-title" class="mt-2 font-heading font-semibold text-off-white text-2xl md:text-3xl leading-tight"></h2>
      <p id="project-modal-meta" class="mt-3 text-concrete-gray text-sm"></p>
      <div id="project-modal-image" class="mt-8 relative aspect-video overflow-hidden bg-charcoal">
        <div class="modal-empty absolute inset-0 bg-gradient-to-br from-charcoal via-deep-gray to-charcoal flex items-end p-5">
          <span class="text-bronze/40 font-heading text-[10px] tracking-[0.28em] uppercase">Photo Coming Soon</span>
        </div>
        <img class="modal-photo hidden absolute inset-0 w-full h-full object-cover" alt="" />
      </div>
      <p class="mt-6 text-concrete-gray text-sm leading-relaxed">
        Detailed project photos, videos, and before-and-after views will be added soon. To inquire about a similar project for your space, request a quote.
      </p>
      <div class="mt-8">
        <a
          href="/contact"
          class="inline-flex items-center px-6 py-3 bg-bronze text-charcoal text-xs font-semibold uppercase tracking-[0.18em] hover:bg-stone-beige transition-colors"
        >
          Request a Similar Project
        </a>
      </div>
    </div>
  </div>

  <CTASection />
</BaseLayout>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('.project-filter');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');
  const empty = document.getElementById('project-empty');

  const applyFilter = (value: string) => {
    let visible = 0;
    cards.forEach((card) => {
      const match = value === 'All' || card.dataset.category === value;
      card.classList.toggle('hidden', !match);
      if (match) visible++;
    });
    if (empty) empty.classList.toggle('hidden', visible !== 0);
  };

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      filters.forEach((other) => {
        other.classList.remove('bg-bronze', 'text-charcoal');
        other.classList.add('text-concrete-gray', 'hover:text-off-white', 'hover:bg-charcoal/60');
        other.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('bg-bronze', 'text-charcoal');
      btn.classList.remove('text-concrete-gray', 'hover:text-off-white', 'hover:bg-charcoal/60');
      btn.setAttribute('aria-pressed', 'true');
      applyFilter(btn.dataset.filter ?? 'All');
    });
  });

  // Lightbox
  const modal = document.getElementById('project-modal');
  const modalClose = document.getElementById('project-modal-close');
  const modalEyebrow = document.getElementById('project-modal-eyebrow');
  const modalTitle = document.getElementById('project-modal-title');
  const modalMeta = document.getElementById('project-modal-meta');

  const openModal = (card: HTMLElement) => {
    if (!modal || !modalTitle || !modalMeta || !modalEyebrow) return;
    modalEyebrow.textContent = card.dataset.type ?? '';
    modalTitle.textContent = card.dataset.title ?? '';
    modalMeta.textContent = `${card.dataset.service} · ${card.dataset.location}`;
    const photo = modal.querySelector<HTMLImageElement>('.modal-photo');
    const empty = modal.querySelector<HTMLElement>('.modal-empty');
    const src = card.dataset.image;
    if (photo && empty) {
      if (src) {
        photo.src = src;
        photo.alt = card.dataset.title ?? '';
        photo.classList.remove('hidden');
        empty.classList.add('hidden');
      } else {
        photo.removeAttribute('src');
        photo.classList.add('hidden');
        empty.classList.remove('hidden');
      }
    }
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  };

  const closeModal = () => {
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  };

  cards.forEach((card) => {
    card.addEventListener('click', () => openModal(card));
  });

  modalClose?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
