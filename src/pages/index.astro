---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTASection from '../components/CTASection.astro';
import {
  customers,
  differentiators,
  heroImage,
  heroTrustPoints,
  processSteps,
  services,
} from '../data/site';
---

<BaseLayout
  title="Stone Coating & Resinous | Premium Flooring Renovation in Oklahoma"
  description="Stone Coating & Resinous provides professional flooring renovation across Oklahoma, including epoxy coatings, resinous flooring, polished concrete, concrete sealing, stone finishes, garage floors, patios, driveways, and concrete repair."
>
  <!-- Hero — Full-bleed photo + navy gradient overlay -->
  <section class="relative min-h-[100vh] flex items-end overflow-hidden bg-navy">
    {heroImage && (
      <img
        src={heroImage}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        decoding="sync"
      />
    )}
    <div class="absolute inset-0" aria-hidden="true">
      {!heroImage && (
        <div
          class="absolute inset-0 opacity-40 mix-blend-screen"
          style="background-image: radial-gradient(circle at 25% 15%, rgba(77,184,255,0.4), transparent 45%), radial-gradient(circle at 80% 80%, rgba(20,92,255,0.28), transparent 55%);"
        ></div>
      )}
      <!-- Bottom-up navy gradient: photo reads cleanly at the top,
           deepens toward the headline area so the white wording pops. -->
      <div class="absolute inset-0 bg-[linear-gradient(0deg,rgba(11,31,58,0.92)_0%,rgba(11,31,58,0.55)_45%,rgba(11,31,58,0.10)_100%)]"></div>
      <!-- Royal-blue corner glow for premium feel -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse at 100% 100%, rgba(20,92,255,0.20), transparent 55%);"
      ></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-10 pt-40 pb-16 lg:pb-24 w-full">
      <div class="flex items-center gap-3 mb-7">
        <span class="block w-12 h-px bg-gradient-to-r from-sky-blue to-royal-blue"></span>
        <p class="text-white text-[11px] font-semibold uppercase tracking-[0.32em]">
          Oklahoma Flooring Specialists
        </p>
      </div>
      <h1 class="font-heading font-semibold text-4xl md:text-6xl lg:text-7xl text-white max-w-5xl leading-[1.02] tracking-tight">
        <span class="text-sky-blue">Premium</span> Flooring Systems with a Polished, High-Performance Finish
      </h1>
      <p class="mt-7 text-white text-lg md:text-xl max-w-2xl leading-relaxed font-medium drop-shadow-[0_1px_8px_rgba(0,0,0,0.55)]">
        Stone Coating &amp; Resinous provides professional flooring renovation across Oklahoma, including epoxy coatings, resinous flooring, polished concrete, concrete sealing, stone finishes, garage floors, patios, driveways, and concrete repair.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <Button href="/contact">Request a Quote</Button>
        <Button href="/services" variant="secondary">Explore Services</Button>
      </div>

      <ul class="mt-20 grid grid-cols-2 lg:grid-cols-4 border-t border-sky-blue/20">
        {heroTrustPoints.map((point) => (
          <li class="border-b border-sky-blue/20 lg:border-b-0 lg:border-r last:border-r-0 first:lg:border-l-0 border-sky-blue/20 py-5 lg:py-6 lg:px-6 first:pr-6 lg:first:pl-0">
            <span class="block text-white text-sm md:text-base font-heading font-medium leading-snug">{point}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- What We Do — Ice gray (light) -->
  <section class="py-20 md:py-28 bg-ice-gray">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <SectionHeading
        tone="light"
        eyebrow="What We Do"
        title="Flooring Systems Built for Performance and Appearance"
        description="We renovate and upgrade concrete surfaces with professional-grade coatings and finishing systems. Every project is evaluated for surface condition, traffic, exposure, appearance, and long-term maintenance — then matched to the right system for the space."
      />

      <ul class="mt-16 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">
        {services.slice(0, 10).map((s) => (
          <li class="group relative overflow-hidden rounded-md border border-silver bg-white p-5 hover:border-sky-blue/50 hover:shadow-gloss-card transition-all duration-300">
            <span class="absolute top-0 left-0 right-0 h-[2px] bg-gloss-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
            <a href={`/services#${s.slug}`} class="block text-navy text-sm md:text-base font-heading font-medium group-hover:text-royal-blue transition-colors">
              {s.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- What Makes Us Different — Deep navy (dark) -->
  <section class="relative py-20 md:py-28 bg-navy overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse at 100% 0%, rgba(77,184,255,0.18), transparent 50%);"
    ></div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <SectionHeading
          eyebrow="Our Approach"
          title="A Professional Flooring Partner, Not Just an Installer"
          description="Flooring renovation requires more than applying a coating. Every project must be evaluated for surface condition, durability requirements, moisture exposure, foot traffic, safety, appearance, and long-term maintenance. We approach every project with a professional process designed to deliver clean finishes, durable results, and clear communication from start to completion."
        />
      </div>
      <div class="lg:col-span-7 grid sm:grid-cols-2 gap-5">
        {differentiators.map((d) => (
          <div class="relative overflow-hidden rounded-lg border border-sky-blue/25 bg-deep-blue/40 backdrop-blur-sm p-7 hover:border-sky-blue/60 hover:shadow-gloss-card-dark transition-all duration-300">
            <span class="absolute top-0 left-0 right-0 h-[2px] bg-gloss-accent"></span>
            <h3 class="font-heading font-semibold text-sky-blue text-lg leading-snug">{d.title}</h3>
            <p class="mt-3 text-ice-gray/80 text-sm leading-relaxed">{d.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who We Serve — White (light) -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <SectionHeading
        tone="light"
        eyebrow="Who We Serve"
        title="Flooring Solutions for Every Type of Property"
        description="From single-car garages to multi-thousand-square-foot industrial facilities, we deliver flooring systems matched to the demands of each environment."
      />
      <div class="mt-16 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {customers.map((c) => (
          <article class="group relative overflow-hidden rounded-lg border border-silver bg-white p-7 shadow-gloss-card hover:-translate-y-1 hover:shadow-gloss-glow hover:border-sky-blue/50 transition-all duration-300">
            <span class="absolute top-0 left-0 right-0 h-[2px] bg-gloss-accent"></span>
            <h3 class="font-heading font-semibold text-navy text-base leading-snug">{c.title}</h3>
            <p class="mt-3 text-ink/75 text-sm leading-relaxed text-justify hyphens-auto">{c.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Preview — Ice gray (light) -->
  <!-- Process — Hero gradient (dark, glossy) -->
  <section class="relative py-20 md:py-28 bg-hero-gradient overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse at 50% 100%, rgba(77,184,255,0.22), transparent 55%);"
    ></div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-10">
      <SectionHeading
        eyebrow="Process"
        title="Our Flooring Renovation Process"
        description="A structured, step-by-step approach from consultation through final review."
      />
      <ol class="mt-16 grid md:grid-cols-2 lg:grid-cols-5 gap-5">
        {processSteps.map((step) => (
          <li class="relative overflow-hidden rounded-lg border border-sky-blue/25 bg-deep-blue/40 backdrop-blur-sm p-7 flex flex-col hover:border-sky-blue/60 hover:shadow-gloss-card-dark transition-all duration-300">
            <span class="absolute top-0 left-0 right-0 h-[2px] bg-gloss-accent"></span>
            <span class="font-heading font-bold text-3xl tracking-tight bg-gradient-to-r from-sky-blue to-royal-blue bg-clip-text text-transparent">{step.num}</span>
            <h3 class="mt-5 font-heading font-semibold text-white text-lg leading-snug">{step.title}</h3>
            <p class="mt-3 text-ice-gray/80 text-sm leading-relaxed">{step.description}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Final CTA — Hero gradient (dark) -->
  <CTASection />
</BaseLayout>
