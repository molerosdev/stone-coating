---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Stone Coating & Resinous | Flooring Renovation in Oklahoma">
  <main class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-3xl">
      <p class="text-bronze tracking-[0.3em] uppercase text-xs mb-6">Coming Soon</p>
      <h1 class="font-heading font-semibold text-4xl md:text-6xl mb-6 leading-tight">
        Stone Coating &amp; Resinous
      </h1>
      <p class="text-concrete-gray text-lg md:text-xl leading-relaxed">
        Premium flooring renovation for residential, commercial, and industrial spaces across Oklahoma.
      </p>
    </div>
  </main>
</BaseLayout>
