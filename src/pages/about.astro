---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTASection from '../components/CTASection.astro';
import { values, whyChooseUs } from '../data/site';
---

<BaseLayout
  title="About Stone Coating & Resinous | Oklahoma Flooring Specialists"
  description="Stone Coating & Resinous delivers professional flooring renovation systems for residential, commercial, and industrial spaces across Oklahoma. Learn about our company, mission, and approach."
>
  <PageHero
    eyebrow="About"
    title="About Stone Coating & Resinous"
    subtitle="Professional flooring renovation solutions for residential, commercial, and industrial spaces across Oklahoma."
  />

  <!-- Company Story -->
  <section class="py-20 md:py-28 bg-charcoal">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-12 gap-12 items-start">
      <div class="lg:col-span-5">
        <SectionHeading eyebrow="Our Story" title="Built on Preparation, Performance, and Premium Finish" />
      </div>
      <div class="lg:col-span-7 text-concrete-gray text-lg leading-relaxed space-y-5">
        <p>
          Stone Coating &amp; Resinous was created to provide property owners, contractors, and businesses with durable, professional flooring systems that improve both appearance and performance.
        </p>
        <p>
          Our work focuses on proper preparation, high-quality materials, clean installation, and long-term value. Every project is matched to its environment — residential garage, commercial showroom, industrial warehouse — and built to hold up to the way that space is actually used.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-20 md:py-28 bg-deep-gray">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <SectionHeading eyebrow="Mission" title="Surfaces Built for Performance and Long-Term Value" />
      </div>
      <div class="lg:col-span-7 text-concrete-gray text-lg leading-relaxed">
        <p>
          To deliver professional flooring renovation systems that protect, enhance, and transform concrete surfaces for homes, businesses, and industrial spaces.
        </p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 md:py-28 bg-charcoal">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <SectionHeading
        eyebrow="Values"
        title="What Guides Every Project"
        description="The standards we apply to every flooring renovation, from a residential garage to an industrial facility."
      />
      <ul class="mt-16 grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-deep-gray border border-deep-gray">
        {values.map((value, idx) => (
          <li class="bg-charcoal p-7 flex items-start gap-5">
            <span class="font-heading font-semibold text-bronze text-sm tracking-widest pt-1">
              {String(idx + 1).padStart(2, '0')}
            </span>
            <span class="font-heading text-off-white text-lg leading-snug">{value}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Why Clients Choose Us -->
  <section class="py-20 md:py-28 bg-deep-gray">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <SectionHeading
        eyebrow="Why Clients Choose Us"
        title="A Flooring Partner You Can Plan Around"
        description="What property owners, contractors, and facility managers can expect when working with us."
      />
      <div class="mt-16 grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-charcoal/40 border border-charcoal/40">
        {whyChooseUs.map((item) => (
          <article class="bg-deep-gray p-7">
            <h3 class="font-heading font-semibold text-off-white text-lg leading-snug">{item.title}</h3>
            <p class="mt-3 text-concrete-gray text-sm leading-relaxed">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Start Your Flooring Project With Us"
    description="Tell us about your space and we'll review the right system for your goals, traffic, and environment."
  />
</BaseLayout>
