---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTASection from '../components/CTASection.astro';
import { values, whyChooseUs } from '../data/site';
---

<BaseLayout
  title="About Stone Coating & Resinous | Oklahoma Flooring Specialists"
  description="Stone Coating & Resinous delivers professional flooring renovation systems for residential, commercial, and industrial spaces across Oklahoma. Learn about our company, mission, and approach."
>
  <PageHero
    eyebrow="About"
    title="About Stone Coating & Resinous"
    subtitle="Professional flooring renovation solutions for residential, commercial, and industrial spaces across Oklahoma."
  />

  <!-- Story — White -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-12 gap-12 items-start">
      <div class="lg:col-span-5">
        <SectionHeading tone="light" eyebrow="Our Story" title="Built on Preparation, Performance, and Premium Finish" />
      </div>
      <div class="lg:col-span-7 text-ink/80 text-lg leading-relaxed space-y-5">
        <p>
          Stone Coating &amp; Resinous was created to provide property owners, contractors, and businesses with durable, professional flooring systems that improve both appearance and performance.
        </p>
        <p>
          Our work focuses on proper preparation, high-quality materials, clean installation, and long-term value. Every project is matched to its environment — residential garage, commercial showroom, industrial warehouse — and built to hold up to the way that space is actually used.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission — Deep navy -->
  <section class="relative py-20 md:py-28 bg-navy overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse at 0% 50%, rgba(77,184,255,0.18), transparent 55%);"
    ></div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <SectionHeading eyebrow="Mission" title="Surfaces Built for Performance and Long-Term Value" />
      </div>
      <div class="lg:col-span-7 text-ice-gray/85 text-lg leading-relaxed">
        <p>
          To deliver professional flooring renovation systems that protect, enhance, and transform concrete surfaces for homes, businesses, and industrial spaces.
        </p>
      </div>
    </div>
  </section>

  <!-- Values — Ice gray (light) -->
  <section class="py-20 md:py-28 bg-ice-gray">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <SectionHeading
        tone="light"
        eyebrow="Values"
        title="What Guides Every Project"
        description="The standards we apply to every flooring renovation, from a residential garage to an industrial facility."
      />
      <ul class="mt-16 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {values.map((value, idx) => (
          <li class="relative overflow-hidden rounded-lg border border-silver bg-white p-7 flex items-start gap-5 shadow-gloss-card hover:-translate-y-1 hover:shadow-gloss-glow hover:border-sky-blue/50 transition-all duration-300">
            <span class="absolute top-0 left-0 right-0 h-[2px] bg-gloss-accent"></span>
            <span class="font-heading font-bold text-sm tracking-widest pt-1 bg-gradient-to-r from-royal-blue to-sky-blue bg-clip-text text-transparent">
              {String(idx + 1).padStart(2, '0')}
            </span>
            <span class="font-heading text-navy text-lg leading-snug">{value}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Why Choose Us — Deep navy -->
  <section class="relative py-20 md:py-28 bg-navy overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(ellipse at 100% 0%, rgba(20,92,255,0.22), transparent 50%);"
    ></div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-10">
      <SectionHeading
        eyebrow="Why Clients Choose Us"
        title="A Flooring Partner You Can Plan Around"
        description="What property owners, contractors, and facility managers can expect when working with us."
      />
      <div class="mt-16 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {whyChooseUs.map((item) => (
          <article class="relative overflow-hidden rounded-lg border border-sky-blue/25 bg-deep-blue/40 backdrop-blur-sm p-7 hover:border-sky-blue/60 hover:shadow-gloss-card-dark transition-all duration-300">
            <span class="absolute top-0 left-0 right-0 h-[2px] bg-gloss-accent"></span>
            <h3 class="font-heading font-semibold text-sky-blue text-lg leading-snug">{item.title}</h3>
            <p class="mt-3 text-ice-gray/80 text-sm leading-relaxed">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Start Your Flooring Project With Us"
    description="Tell us about your space and we'll review the right system for your goals, traffic, and environment."
  />
</BaseLayout>
