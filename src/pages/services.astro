---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Button from '../components/Button.astro';
import CTASection from '../components/CTASection.astro';
import { services } from '../data/site';
---

<BaseLayout
  title="Epoxy, Resinous & Polished Concrete Flooring Services in Oklahoma"
  description="From epoxy flooring and resinous systems to polished concrete, sealing, stone coating, and concrete repair, Stone Coating & Resinous provides complete surface solutions for residential, commercial, and industrial properties in Oklahoma."
>
  <PageHero
    eyebrow="Services"
    title="Professional Flooring Renovation Services"
    subtitle="From epoxy flooring and resinous systems to polished concrete, sealing, stone coating, and concrete repair, we provide complete surface solutions for residential, commercial, and industrial properties."
  />

  <!-- Service jump-nav -->
  <section class="py-10 bg-deep-gray border-b border-charcoal/40">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <ul class="flex flex-wrap gap-2">
        {services.map((s) => (
          <li>
            <a
              href={`#${s.slug}`}
              class="inline-flex px-4 py-2 border border-charcoal/40 text-xs uppercase tracking-[0.18em] text-concrete-gray hover:text-bronze hover:border-bronze/60 transition-colors"
            >
              {s.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Service sections -->
  <div class="bg-charcoal">
    {
      services.map((service, idx) => (
        <section
          id={service.slug}
          class:list={[
            'py-20 md:py-24 scroll-mt-24',
            idx % 2 === 0 ? 'bg-charcoal' : 'bg-deep-gray',
          ]}
        >
          <div class="max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-12 gap-12">
            <div class="lg:col-span-5">
              <p class="text-bronze text-xs font-semibold uppercase tracking-[0.3em] mb-5">
                {String(idx + 1).padStart(2, '0')} &nbsp;/&nbsp; Service
              </p>
              <h2 class="font-heading font-semibold text-3xl md:text-4xl text-off-white leading-tight">
                {service.title}
              </h2>
              <p class="mt-5 text-concrete-gray text-lg leading-relaxed">{service.short}</p>
              <Button href={`/contact?service=${encodeURIComponent(service.title)}`} class="mt-8">
                Request This Service
              </Button>
            </div>
            <div class="lg:col-span-7 grid sm:grid-cols-2 gap-6">
              <div class="border border-bronze/20 p-7">
                <h3 class="font-heading text-off-white text-sm uppercase tracking-[0.22em] font-semibold">
                  Best Use Cases
                </h3>
                <ul class="mt-5 space-y-3">
                  {service.useCases.map((useCase) => (
                    <li class="flex items-start gap-3 text-concrete-gray text-sm leading-relaxed">
                      <span class="mt-2 w-1 h-1 bg-bronze shrink-0" aria-hidden="true" />
                      <span>{useCase}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="border border-bronze/20 p-7">
                <h3 class="font-heading text-off-white text-sm uppercase tracking-[0.22em] font-semibold">
                  Benefits
                </h3>
                <ul class="mt-5 space-y-3">
                  {service.benefits.map((benefit) => (
                    <li class="flex items-start gap-3 text-concrete-gray text-sm leading-relaxed">
                      <span class="mt-2 w-1 h-1 bg-bronze shrink-0" aria-hidden="true" />
                      <span>{benefit}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </section>
      ))
    }
  </div>

  <CTASection />
</BaseLayout>
