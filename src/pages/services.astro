---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Button from '../components/Button.astro';
import CTASection from '../components/CTASection.astro';
import { flooringServices } from '../data/site';

const imageUrl = (folder: string, file: string) =>
  `/images/${encodeURIComponent(folder)}/${encodeURIComponent(file)}`;

// Map service slug -> ordered list of full image URLs. Injected as JSON so
// the client-side lightbox can navigate within a single service's gallery.
const galleryData = Object.fromEntries(
  flooringServices.map((s) => [
    s.slug,
    {
      title: s.title,
      images: s.images.map((file) => imageUrl(s.folder, file)),
    },
  ]),
);
---

<BaseLayout
  title="Flooring Services in Oklahoma | Stone Coating & Resinous"
  description="Polished concrete, epoxy flake, epoxy quartz, metallic epoxy, terrazzo restoration, stone coating, carpet, tile, and wood — commercial flooring systems by Stone Coating & Resinous across Oklahoma."
>
  <PageHero
    eyebrow="Services"
    title="Professional Flooring Renovation Services"
    subtitle="Commercial flooring systems engineered for performance, sanitation, and appearance — selected and installed to match the demands of your space."
  />

  <!-- Jump-nav -->
  <section class="py-10 bg-ice-gray border-b border-silver">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <ul class="flex flex-wrap gap-2">
        {flooringServices.map((s) => (
          <li>
            <a
              href={`#${s.slug}`}
              class="inline-flex px-4 py-2 rounded-full border border-silver text-xs uppercase tracking-[0.18em] text-navy/75 bg-white hover:text-royal-blue hover:border-royal-blue/50 hover:shadow-[0_6px_16px_rgba(20,92,255,0.12)] transition-all duration-300"
            >
              {s.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Service sections — alternating white / navy -->
  <div>
    {
      flooringServices.map((service, idx) => {
        const dark = idx % 2 === 1;
        return (
          <section
            id={service.slug}
            class:list={[
              'relative py-20 md:py-24 scroll-mt-24 overflow-hidden',
              dark ? 'bg-navy' : 'bg-white',
            ]}
          >
            {dark && (
              <div
                class="absolute inset-0 pointer-events-none"
                aria-hidden="true"
                style="background: radial-gradient(ellipse at 100% 0%, rgba(77,184,255,0.16), transparent 55%);"
              ></div>
            )}

            <div class="relative max-w-7xl mx-auto px-6 lg:px-10">
              <div class="grid lg:grid-cols-12 gap-10 lg:gap-12">
                <div class="lg:col-span-5">
                  <h2 class:list={[
                    'font-heading font-semibold text-3xl md:text-4xl leading-tight tracking-tight',
                    dark ? 'text-white' : 'text-navy',
                  ]}>
                    {service.title}
                  </h2>
                  <p class:list={[
                    'mt-5 text-lg leading-relaxed',
                    dark ? 'text-ice-gray/85' : 'text-ink/75',
                  ]}>
                    {service.blurb}
                  </p>
                  {service.details && (
                    <p class:list={[
                      'mt-4 text-base leading-relaxed',
                      dark ? 'text-ice-gray/70' : 'text-ink/65',
                    ]}>
                      {service.details}
                    </p>
                  )}

                  {(service.highlights?.length || service.applications?.length) && (
                    <div class="mt-7 grid gap-6 sm:grid-cols-2">
                      {service.highlights && service.highlights.length > 0 && (
                        <div>
                          <h3 class:list={[
                            'font-heading text-xs uppercase tracking-[0.22em] font-semibold',
                            dark ? 'text-sky-blue' : 'text-royal-blue',
                          ]}>
                            Highlights
                          </h3>
                          <ul class="mt-3 space-y-2">
                            {service.highlights.map((h) => (
                              <li class:list={[
                                'flex items-start gap-3 text-sm leading-relaxed',
                                dark ? 'text-ice-gray/85' : 'text-ink/80',
                              ]}>
                                <span class:list={[
                                  'mt-2 w-1.5 h-1.5 rounded-full shrink-0',
                                  dark ? 'bg-sky-blue' : 'bg-royal-blue',
                                ]} aria-hidden="true" />
                                <span>{h}</span>
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}
                      {service.applications && service.applications.length > 0 && (
                        <div>
                          <h3 class:list={[
                            'font-heading text-xs uppercase tracking-[0.22em] font-semibold',
                            dark ? 'text-sky-blue' : 'text-royal-blue',
                          ]}>
                            Common Applications
                          </h3>
                          <ul class="mt-3 space-y-2">
                            {service.applications.map((a) => (
                              <li class:list={[
                                'flex items-start gap-3 text-sm leading-relaxed',
                                dark ? 'text-ice-gray/85' : 'text-ink/80',
                              ]}>
                                <span class:list={[
                                  'mt-2 w-1.5 h-1.5 rounded-full shrink-0',
                                  dark ? 'bg-sky-blue' : 'bg-royal-blue',
                                ]} aria-hidden="true" />
                                <span>{a}</span>
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}
                    </div>
                  )}

                  <Button
                    href={`/contact?service=${encodeURIComponent(service.title)}`}
                    class="mt-9"
                  >
                    Request This Service
                  </Button>
                </div>

                <!-- Image grid -->
                <div class="lg:col-span-7">
                  {service.images.length > 0 ? (
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 sm:gap-4">
                      {service.images.map((file, i) => (
                        <button
                          type="button"
                          data-gallery={service.slug}
                          data-index={i}
                          class:list={[
                            'gallery-thumb group relative overflow-hidden rounded-lg block text-left cursor-zoom-in',
                            'border focus:outline-none focus-visible:ring-2 focus-visible:ring-royal-blue',
                            dark ? 'border-sky-blue/25' : 'border-silver',
                            // First image spans 2 cols on small/sm grids for a hero tile.
                            i === 0 ? 'col-span-2 row-span-2 aspect-[4/3]' : 'aspect-square',
                          ]}
                          aria-label={`Open ${service.title} photo ${i + 1} of ${service.images.length}`}
                        >
                          <img
                            src={imageUrl(service.folder, file)}
                            alt={`${service.title} – project ${i + 1}`}
                            loading="lazy"
                            decoding="async"
                            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                          />
                          <span class="absolute top-0 left-0 right-0 h-[2px] bg-gloss-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
                          <span class="absolute inset-0 bg-gradient-to-t from-navy/55 via-navy/0 to-transparent opacity-90 group-hover:from-royal-blue/55 transition-all duration-500"></span>
                          <span class="absolute inset-0 bg-card-shine opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></span>
                        </button>
                      ))}
                    </div>
                  ) : (
                    <div class:list={[
                      'relative overflow-hidden rounded-lg border p-10 flex items-center justify-center min-h-[260px]',
                      dark ? 'border-sky-blue/25 bg-deep-blue/40 backdrop-blur-sm' : 'border-silver bg-ice-gray',
                    ]}>
                      <span class="absolute top-0 left-0 right-0 h-[2px] bg-gloss-accent"></span>
                      <p class:list={[
                        'text-center text-sm font-heading uppercase tracking-[0.28em]',
                        dark ? 'text-sky-blue/70' : 'text-royal-blue/70',
                      ]}>
                        Photos coming soon
                      </p>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </section>
        );
      })
    }
  </div>

  <CTASection />

  <!-- Lightbox modal — shared across all service galleries -->
  <div
    id="gallery-modal"
    class="fixed inset-0 z-[70] hidden items-center justify-center bg-navy/95 backdrop-blur-md p-4 md:p-8"
    role="dialog"
    aria-modal="true"
    aria-labelledby="gallery-modal-title"
  >
    <!-- Top bar -->
    <div class="absolute inset-x-0 top-0 flex items-center justify-between gap-4 px-4 md:px-8 py-4 md:py-6 text-white">
      <div class="min-w-0">
        <p id="gallery-modal-title" class="font-heading font-semibold text-base md:text-lg truncate"></p>
        <p id="gallery-modal-count" class="text-sky-blue text-xs md:text-sm uppercase tracking-[0.22em] font-semibold mt-1"></p>
      </div>
      <button
        id="gallery-modal-close"
        type="button"
        class="shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-full border border-white/20 bg-white/10 hover:bg-white/20 transition-colors"
        aria-label="Close gallery"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M6 6l12 12M18 6l-12 12" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <!-- Prev / Next buttons -->
    <button
      id="gallery-prev"
      type="button"
      class="absolute left-3 md:left-8 top-1/2 -translate-y-1/2 inline-flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-full border border-white/20 bg-white/10 hover:bg-white/20 text-white transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
      aria-label="Previous photo"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <path d="M15 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
    <button
      id="gallery-next"
      type="button"
      class="absolute right-3 md:right-8 top-1/2 -translate-y-1/2 inline-flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-full border border-white/20 bg-white/10 hover:bg-white/20 text-white transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
      aria-label="Next photo"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>

    <!-- Image -->
    <figure class="relative max-w-6xl w-full max-h-[80vh] flex items-center justify-center">
      <img
        id="gallery-modal-image"
        src=""
        alt=""
        class="max-h-[80vh] w-auto max-w-full object-contain rounded-lg shadow-gloss-glow"
      />
    </figure>
  </div>

  <!-- Gallery data injected for the lightbox JS -->
  <script id="gallery-data" type="application/json" set:html={JSON.stringify(galleryData)}></script>
</BaseLayout>

<script>
  type GalleryEntry = { title: string; images: string[] };

  const dataEl = document.getElementById('gallery-data');
  const data: Record<string, GalleryEntry> = dataEl?.textContent ? JSON.parse(dataEl.textContent) : {};

  const modal = document.getElementById('gallery-modal');
  const image = document.getElementById('gallery-modal-image') as HTMLImageElement | null;
  const titleEl = document.getElementById('gallery-modal-title');
  const countEl = document.getElementById('gallery-modal-count');
  const closeBtn = document.getElementById('gallery-modal-close');
  const prevBtn = document.getElementById('gallery-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('gallery-next') as HTMLButtonElement | null;

  let currentSlug: string | null = null;
  let currentIndex = 0;

  const render = () => {
    if (!currentSlug) return;
    const entry = data[currentSlug];
    if (!entry || entry.images.length === 0) return;
    const total = entry.images.length;
    // Wrap-around so prev/next always advance.
    currentIndex = ((currentIndex % total) + total) % total;
    if (image) {
      image.src = entry.images[currentIndex];
      image.alt = `${entry.title} – project ${currentIndex + 1}`;
    }
    if (titleEl) titleEl.textContent = entry.title;
    if (countEl) countEl.textContent = `${currentIndex + 1} / ${total}`;
  };

  const open = (slug: string, index: number) => {
    if (!modal || !data[slug]) return;
    currentSlug = slug;
    currentIndex = index;
    render();
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  };

  const close = () => {
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
    currentSlug = null;
    if (image) image.src = '';
  };

  const prev = () => {
    if (!currentSlug) return;
    currentIndex -= 1;
    render();
  };
  const next = () => {
    if (!currentSlug) return;
    currentIndex += 1;
    render();
  };

  document.querySelectorAll<HTMLButtonElement>('.gallery-thumb').forEach((btn) => {
    btn.addEventListener('click', () => {
      const slug = btn.dataset.gallery;
      const idx = Number(btn.dataset.index ?? '0');
      if (slug) open(slug, idx);
    });
  });

  closeBtn?.addEventListener('click', close);
  prevBtn?.addEventListener('click', prev);
  nextBtn?.addEventListener('click', next);

  // Click background to close, but ignore clicks on the controls / image.
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) close();
  });

  // Keyboard: Esc to close, arrows to navigate.
  document.addEventListener('keydown', (e) => {
    if (!currentSlug) return;
    if (e.key === 'Escape') close();
    else if (e.key === 'ArrowLeft') prev();
    else if (e.key === 'ArrowRight') next();
  });

  // Touch swipe navigation on the modal image.
  let touchStartX = 0;
  let touchStartY = 0;
  modal?.addEventListener('touchstart', (e) => {
    const t = e.touches[0];
    touchStartX = t.clientX;
    touchStartY = t.clientY;
  }, { passive: true });
  modal?.addEventListener('touchend', (e) => {
    const t = e.changedTouches[0];
    const dx = t.clientX - touchStartX;
    const dy = t.clientY - touchStartY;
    if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
      if (dx < 0) next();
      else prev();
    }
  });
</script>
